# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
APP_NAME=FAMS
APP_ENV=production              # local | staging | production
APP_KEY=                        # Run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file     # file | database
# APP_MAINTENANCE_STORE=database
# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12                # increase for stronger hashing (costs more CPU)

# ─────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                 # debug | info | notice | warning | error | critical

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db                      # use 127.0.0.1 if not running in Docker
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ─────────────────────────────────────────
# INTERNAL API
# ─────────────────────────────────────────
API_BASE_URI=http://localhost:8003/api
API_KEY=your_internal_api_key

# ─────────────────────────────────────────
# AUTH API
# ─────────────────────────────────────────
AUTH_API_BASE_URI=https://your-auth-domain.com
AUTH_API_KEY=your_auth_api_key
AUTH_USER_API_KEY=your_auth_user_api_key

# ─────────────────────────────────────────
# SNIPE-IT INTEGRATION
# ─────────────────────────────────────────
SNIPE_URL=http://your-snipe-host/api/v1
SNIPE_TOKEN=your_snipe_api_token  # Generate from Snipe-IT → Profile → API Tokens

# ─────────────────────────────────────────
# SESSION
# ─────────────────────────────────────────
SESSION_DRIVER=database         # file | cookie | database | redis
SESSION_LIFETIME=120            # minutes
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─────────────────────────────────────────
# CACHE / QUEUE / BROADCAST
# ─────────────────────────────────────────
BROADCAST_CONNECTION=log        # log | pusher | ably | redis | null
FILESYSTEM_DISK=local           # local | public | s3
QUEUE_CONNECTION=redis          # sync | database | redis | sqs
CACHE_STORE=file                # database | redis | file | memcached
# CACHE_PREFIX=

# ─────────────────────────────────────────
# MEMCACHED (only if CACHE_STORE=memcached)
# ─────────────────────────────────────────
MEMCACHED_HOST=127.0.0.1

# ─────────────────────────────────────────
# REDIS (only if using redis for cache/queue)
# ─────────────────────────────────────────
REDIS_CLIENT=predis             # phpredis | predis
REDIS_HOST=redis                # use 127.0.0.1 if not running in Docker
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────
# MAIL
# ─────────────────────────────────────────
MAIL_MAILER=log                 # smtp | mailgun | ses | postmark | sendmail | log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────
# AWS S3 (only if FILESYSTEM_DISK=s3)
# ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─────────────────────────────────────────
# GOOGLE DRIVE — Spatie Backup (coming soon)
# ─────────────────────────────────────────
GOOGLE_DRIVE_CLIENT_ID=         # OAuth 2.0 Client ID from Google Cloud Console
GOOGLE_DRIVE_CLIENT_SECRET=     # OAuth 2.0 Client Secret
GOOGLE_DRIVE_REFRESH_TOKEN=     # Generate via OAuth playground or artisan command
GOOGLE_DRIVE_FOLDER="Your Backup Folder/SubFolder"

# ─────────────────────────────────────────
# VITE
# ─────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
